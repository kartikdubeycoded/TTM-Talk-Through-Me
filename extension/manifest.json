{
  "manifest_version": 3,
  "name": "Talk Through Me",
  "version": "1.0",
  "description": "Talk Through Me (TTM) — live sign-language captions on your video calls. Your webcam never leaves your machine.",
  "permissions": [
    "storage",
    "offscreen"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://meet.google.com/*",
        "*://*.zoom.us/*",
        "*://teams.microsoft.com/*",
        "*://teams.live.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "overlay.css"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": []
}
